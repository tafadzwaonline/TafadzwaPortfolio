@page "/project-9"

@layout HeaderLayout

<section class="project-cs-hero">
    <div class="project-cs-hero__content">
        <h1 class="heading-primary">Managefy</h1>
        <div class="project-cs-hero__info">
            <p class="text-primary">
                This page contains the case study of Managefy, including the
                project overview, production stack, and live product link.
            </p>
        </div>
    </div>
</section>
<section class="project-details">
    <div class="main-container">
        <div class="project-details__content">
            <div class="project-details__showcase-img-cont">
                <img src="assets/png/managefy_dashbaod.png"
                     alt="Managefy dashboard screen"
                     class="project-details__showcase-img managefy-screenshot managefy-screenshot--dashboard"
                     loading="eager" />
            </div>
            <div class="project-details__content-main">
                <div class="project-details__desc">
                    <h2 class="project-details__content-title">Project Overview</h2>

                    <p class="project-details__desc-para">
                        Managefy is a production-ready business management system built to help teams manage operations from one central platform. It supports quotations, invoices, sale orders, purchase orders, customers, documents, banking details, expenses, receipts, dashboards, and reporting.
                    </p>
                    <p class="project-details__desc-para">
                        The system is integrated with ZIMRA fiscalisation services to generate compliant fiscal invoices, credit notes, and debit notes. It also runs scheduled background checks for fiscal devices and keeps report templates ready for production use.
                    </p>
                    <p class="project-details__desc-para">
                        The platform includes a separate ledger API and a .NET MAUI mobile app for quick receipt workflows. The architecture uses secure authentication, SQL Server persistence, background jobs, reporting, PDF generation, and mobile data storage to support real business operations.
                    </p>
                </div>
                <div class="project-details__tools-used">
                    <h2 class="project-details__content-title">Tools Used</h2>
                    <div class="skills">
                        <div class="skills__skill">C#</div>
                        <div class="skills__skill">ASP.NET Core 8</div>
                        <div class="skills__skill">Blazor Server</div>
                        <div class="skills__skill">Razor Components</div>
                        <div class="skills__skill">Entity Framework Core</div>
                        <div class="skills__skill">Microsoft SQL Server</div>
                        <div class="skills__skill">ASP.NET Identity</div>
                        <div class="skills__skill">Google Authentication</div>
                        <div class="skills__skill">Hangfire</div>
                        <div class="skills__skill">DevExpress Blazor</div>
                        <div class="skills__skill">DevExpress Reporting</div>
                        <div class="skills__skill">REST API</div>
                        <div class="skills__skill">Swagger / OpenAPI</div>
                        <div class="skills__skill">QuestPDF</div>
                        <div class="skills__skill">EPPlus</div>
                        <div class="skills__skill">.NET MAUI</div>
                        <div class="skills__skill">SQLite</div>
                        <div class="skills__skill">Git</div>
                        <div class="skills__skill">GitHub</div>
                    </div>
                </div>
                <div class="project-details__links">
                    <h2 class="project-details__content-title">See Live</h2>
                    <a href="https://tafadzwakahwai.ddns.net/Manage/Account/Login" class="btn btn--med btn--theme project-details__links-btn"
                       target="_blank" rel="noreferrer">System Link</a>
                    <a href="assets/files/Managefy.apk" class="btn btn--med btn--theme project-details__links-btn"
                       download="Managefy.apk">Download Android APK</a>
                    <a href="projects" class="btn btn--med btn--theme-inv project-details__links-btn">Go Back</a>
                </div>
            </div>
        </div>
    </div>
</section>
