@page "/project-9"

@layout HeaderLayout

<section class="project-cs-hero">
    <div class="project-cs-hero__content">
        <h1 class="heading-primary">Managefy</h1>
        <div class="project-cs-hero__info">
            <p class="text-primary">
                This page contains the case study of Managefy which includes
                the Project Overview, Tools Used and Live Links to the official
                product.
            </p>
        </div>
    </div>
</section>
<section class="project-details">
    <div class="main-container">
        <div class="project-details__content">
            <div class="project-details__showcase-img-cont">
                <div class="managefy-preview managefy-preview--large" aria-label="Managefy project preview">
                    <div class="managefy-preview__sidebar">
                        <span></span>
                        <span></span>
                        <span></span>
                    </div>
                    <div class="managefy-preview__main">
                        <div class="managefy-preview__topbar"></div>
                        <div class="managefy-preview__stats">
                            <span></span>
                            <span></span>
                            <span></span>
                        </div>
                        <div class="managefy-preview__table">
                            <span></span>
                            <span></span>
                            <span></span>
                            <span></span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="project-details__content-main">
                <div class="project-details__desc">
                    <h2 class="project-details__content-title">Project Overview</h2>

                    <p class="project-details__desc-para">
                        Managefy is a web-based business management system built to help teams manage day-to-day operations from one central platform. It is used to create quotations, invoices, sale orders, purchase orders, and other business documents.
                    </p>
                    <p class="project-details__desc-para">
                        The system is integrated with ZIMRA to generate fiscalised invoices, credit notes, and debit notes. This helps businesses stay compliant while keeping their sales and finance workflows organized in one place.
                    </p>
                    <p class="project-details__desc-para">
                        The system is designed around a clean dashboard experience, practical workflows, and maintainable application structure. I continue to improve the project by refining features, improving usability, and keeping the codebase aligned with modern development practices.
                    </p>
                </div>
                <div class="project-details__tools-used">
                    <h2 class="project-details__content-title">Tools Used</h2>
                    <div class="skills">
                        <div class="skills__skill">HTML</div>
                        <div class="skills__skill">CSS</div>
                        <div class="skills__skill">JavaScript</div>
                        <div class="skills__skill">Bootstrap 5</div>
                        <div class="skills__skill">GIT</div>
                        <div class="skills__skill">Github</div>
                        <div class="skills__skill">C#</div>
                        <div class="skills__skill">SQL</div>
                        <div class="skills__skill">.Net</div>
                        <div class="skills__skill">WebAPI (REST)</div>
                        <div class="skills__skill">Microsoft SQL Server</div>
                    </div>
                </div>
                <div class="project-details__links">
                    <h2 class="project-details__content-title">See Live</h2>
                    <a href="https://mysystem.ddns.net/Managefy/login" class="btn btn--med btn--theme project-details__links-btn"
                       target="_blank" rel="noreferrer">System Link</a>
                    <a href="projects" class="btn btn--med btn--theme-inv project-details__links-btn">Go Back</a>
                </div>
            </div>
        </div>
    </div>
</section>
