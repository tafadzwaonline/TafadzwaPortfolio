@page "/project-6"

@layout HeaderLayout

<section class="project-cs-hero">
    <div class="project-cs-hero__content">
        <h1 class="heading-primary">Salari</h1>
        <div class="project-cs-hero__info">
            <p class="text-primary">
                This page contains the case study of the Salari  which includes
                the Project Overview, Tools Used and Live Links to the official
                product.
            </p>
        </div>

    </div>
</section>
<section class="project-details">
    <div class="main-container">
        <div class="project-details__content">
            <div class="project-details__showcase-img-cont">
                <img src="assets/png/salari.png" alt="Project Image" class="project-details__showcase-img" />
            </div>
            <div class="project-details__content-main">
                <div class="project-details__desc">
                    <div class="project-details__desc">
                        <h2 class="project-details__content-title">
                            Project Overview
                        </h2>
                        <p class="project-details__desc-para">
                            Introducing a web system allows users to enter their gross salary to calculate the possible net salary.
                            The tax tables used for calculations were sourced from the ZIMRA (Zimbabwe Revenue Authority) website. 
                            Feel free to check out the Project by visiting the <strong>Project Link</strong> below.
                        </p>


                    </div>
                </div>
                <div class="project-details__tools-used">
                    <h2 class="project-details__content-title">Tools Used</h2>
                    <div class="skills">
                        <div class="skills__skill">HTML</div>
                        <div class="skills__skill">CSS</div>
                        <div class="skills__skill">JavaScript</div>
                        <div class="skills__skill">Bootstrap 5</div>
                        <div class="skills__skill">C#</div>
                        <div class="skills__skill">SQL</div>
                        <div class="skills__skill">.Net</div>
                        <div class="skills__skill">MS SQL</div>
               
                    </div>
                </div>
                <div class="project-details__links">
                    <h2 class="project-details__content-title">See Live</h2>
                    <a href="https://mysystem.ddns.net/Salari/salary-calculator" class="btn btn--med btn--theme project-details__links-btn"
                       target="_blank" rel="noreferrer">Live Link</a>
                    <a href="projects" class="btn btn--med btn--theme-inv project-details__links-btn">Go Back</a>
                </div>
            </div>
        </div>
    </div>
</section>
